# Mega S4 Credentials
# Get these from: https://mega.nz → Object Storage → Settings → Access Keys
# Copy this file to .env and fill in your credentials
S4_ACCESS_KEY_ID=
S4_SECRET_ACCESS_KEY=
S4_REGION=eu-amsterdam
S4_BUCKET=motherbrain-inventions

# Optional: Override the S3 endpoint (default: https://s3.{region}.megas4.com)
# S4_ENDPOINT=https://s3.eu-amsterdam.megas4.com

# Inventions Registry Publish API (Encore.dev backend)
INVENTIONS_PUBLISH_KEY=

# GitHub repo for releases (default: native-apps/a2a-agent-invention)
# GH_REPO=native-apps/a2a-agent-invention
